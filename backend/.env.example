# copy to .env and adjust
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=postgres
DB_NAME=accuspirals
PORT=3000

# ---- Authentication ----
# Secret used to sign login tokens.
# If you leave this as-is (or delete it), the backend auto-generates a strong random
# secret on first run and saves it to backend/.auth-secret (persists across restarts).
# To set your own instead, put a long random string here.
AUTH_SECRET=change-me-to-a-long-random-string
# Recovery escape hatch: set to false to TEMPORARILY disable all auth (e.g. if locked out).
# Leave as true for normal secured operation.
AUTH_ENABLED=true
